# ─────────────────────────────────────────────────────────────────────────────
# VIMO environment template
#
# Copy this file to `.env` and fill in ONLY what you intend to use.
# VIMO runs with ZERO config for the Demo; the only key required to generate
# content is an AI provider key (OpenAI / Anthropic / Groq / Ollama / …).
#
# NEVER commit your real `.env`. It is git-ignored by default.
# This file is safe to commit — it contains no real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# Core
NODE_ENV=development
PORT=3000
BACKEND_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# Database (SQLite). Use ":memory:" for ephemeral runs, or a file path otherwise.
DB_PATH=./data/vimo.db

# ── SECRETS ──────────────────────────────────────────────────────────────────
# 32+ random chars. ALL API keys / OAuth tokens VIMO stores are encrypted at rest
# (AES-256-GCM) with this key. If you lose or change it, stored credentials become
# unreadable (by design). Generate one with:  openssl rand -hex 32
ENCRYPTION_KEY=your-32-char-random-encryption-key-here

# Optional: Redis for the job queue. VIMO falls back to an in-memory queue if unset.
REDIS_URL=redis://localhost:6379

# Logging verbosity: error | warn | info | debug
LOG_LEVEL=info

# ── OAuth / Connector credentials (ALL OPTIONAL) ──────────────────────────────
# One-click managed providers (GitHub, Notion, Canva, LinkedIn, X) need NO keys
# from you when these are set — VIMO runs the OAuth popup for you. For everything
# below, paste the value shown in that platform's own developer settings; VIMO points
# you to the exact page in the UI.
#
# These values are ONLY used to (a) enable one-click connect and (b) let VIMO prefill
# the OAuth app you register. They are not required to run VIMO. If a managed
# provider's credentials are left blank, VIMO shows the in-app guided setup instead.

# Canva — https://www.canva.com/developers/
VIMO_CANVA_CLIENT_ID=your_canva_client_id
VIMO_CANVA_CLIENT_SECRET=your_canva_client_secret

# GitHub — https://github.com/settings/developers
VIMO_GITHUB_CLIENT_ID=your_github_client_id
VIMO_GITHUB_CLIENT_SECRET=your_github_client_secret

# Notion — https://www.notion.so/my-integrations (token is both id and secret)
VIMO_NOTION_CLIENT_ID=your_notion_integration_token
VIMO_NOTION_CLIENT_SECRET=your_notion_integration_token

# LinkedIn — https://www.linkedin.com/developers/apps (one-click when set)
VIMO_LINKEDIN_CLIENT_ID=your_linkedin_client_id
VIMO_LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret

# X (Twitter) — https://developer.x.com (public OAuth 2.0 client; client id only)
VIMO_X_CLIENT_ID=your_x_client_id

# Google — https://console.cloud.google.com/apis/credentials
VIMO_GOOGLE_CLIENT_ID=your_google_client_id
VIMO_GOOGLE_CLIENT_SECRET=your_google_client_secret

# Slack — https://api.slack.com/apps
VIMO_SLACK_CLIENT_ID=your_slack_client_id
VIMO_SLACK_CLIENT_SECRET=your_slack_client_secret
